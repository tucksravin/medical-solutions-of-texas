{
	"name": "medical-solutions-of-texas",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.1",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "concurrently \"pnpm:vite:dev\" \"pnpm:slicemachine\" --prefix-colors blue,magenta",
		"vite:dev": "vite dev",
		"vite:devHost": "vite dev --host --port 8888",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . --plugin prettier-plugin-svelte . && eslint .",
		"format": "prettier --write . --plugin prettier-plugin-svelte .",
		"slicemachine": "start-slicemachine"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@slicemachine/adapter-sveltekit": "^0.3.60",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.5.27",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"concurrently": "^9.1.2",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-svelte": "^3.1.0",
		"globals": "^17.5.0",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.2.6",
		"slice-machine-ui": "^2.11.1",
		"svelte": "^5.23.0",
		"svelte-check": "^4.0.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"typescript-svelte-plugin": "^0.3.36",
		"vite": "^8.0.2"
	},
	"dependencies": {
		"@lucide/svelte": "^1.8.0",
		"@prismicio/client": "^7.3.1",
		"@prismicio/svelte": "^2.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@zerodevx/svelte-img": "^2.1.2",
		"svelte-gestures": "^5.2.2",
		"svelte-select": "^5.8.3",
		"tailwindcss": "^4.2.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@scarf/scarf",
			"esbuild",
			"sharp"
		]
	}
}
